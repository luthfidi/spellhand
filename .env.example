# ─────────────────────────────────────────────────────────────
# Spellhand — Environment variables
# Copy this file to `.env.local` and fill in values for local dev.
# `.env.local` is gitignored and never committed.
# ─────────────────────────────────────────────────────────────

# ─── Supabase (Phase 2+) ──────────────────────────────────────
# Get these from your Supabase project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...

# Server-only — used for cert issuance + admin operations.
# Never expose to the client. Skip the NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ─── Certificate signing (Phase 3) ────────────────────────────
# HMAC secret used to sign certificate payloads so public share
# pages can verify a certificate without trusting the row alone.
# Generate with: openssl rand -hex 32
CERT_SIGNING_SECRET=

# ─── Public site URL ──────────────────────────────────────────
# Used for OG image absolute URLs, certificate share links, etc.
# In production, set this to your deployed origin.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
