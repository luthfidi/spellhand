# Normalise all text files to LF in the repo, regardless of the OS the
# contributor uses. Prevents the entire diff being "CRLF -> LF" noise.
* text=auto eol=lf

# Explicit overrides for clarity
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.mjs       text eol=lf
*.cjs       text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.css       text eol=lf
*.html      text eol=lf
*.svg       text eol=lf
*.sql       text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Binary files — never normalise
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.woff      binary
*.woff2     binary
*.pdf       binary
